<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CivicReporting.Mobile.MainPage"
             Title="Civic Reporting">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">
            <Label
                Text="Civic Reporting"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Report urban problems to verified government institutions."
                Style="{StaticResource SubHeadline}" />

            <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />

            <Label Text="MVP screens (coming next):" FontAttributes="Bold" />
            <Label Text="• Sign in (Google OAuth)" />
            <Label Text="• New report with photo and location" />
            <Label Text="• Report list and community support" />
            <Label Text="• Map with category icons and legend" />

            <Button
                Text="Placeholder: New report"
                HorizontalOptions="Fill"
                IsEnabled="False" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
